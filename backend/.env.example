# LLM API 配置
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 数据库配置（MySQL 示例，SQLite 改为 sqlite+aiosqlite:///./data/competitor_analysis.db）
DATABASE_URL=mysql+aiomysql://root:12345678@localhost:3306/competitor_analysis?charset=utf8mb4

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
